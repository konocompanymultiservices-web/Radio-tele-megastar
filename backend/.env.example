# ============================================================
# Radio Télé Mega Star — Variables Anviwonnman (EXAMPLE)
# Kopye fichye sa a: cp .env.example .env
# Epi ranpli valè yo — JAMIS mete .env nan GitHub!
# ============================================================

# ===== MongoDB =====
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=YOUR_APP

# ===== JWT Secret =====
# Kreye yon kle solid: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# ===== Mistral API =====
# Ale sou console.mistral.ai pou jwenn kle ou a
MISTRAL_API_KEY=your-mistral-api-key-here

# ===== Email (Gmail) =====
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ===== Admin =====
# Email(s) ki pral jwenn role admin otomatikman (separe ak vigil si plizyè)
ADMIN_EMAILS=admin@example.com
ADMIN_EMAIL=admin@example.com
ADMIN_SECRET_KEY=your-admin-secret-key

# ===== Site URL =====
SITE_URL=https://your-domain.com

# ===== Port =====
PORT=5000
