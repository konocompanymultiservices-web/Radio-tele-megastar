# ============================================================
# Radio Télé Mega Star — Variables Anviwonnman (EXAMPLE)
# Kopye fichye sa a: cp .env.example .env
# Epi ranpli valè yo avèk done reyèl ou — JAMIS push .env sou GitHub!
# ============================================================

# ===== MongoDB Atlas =====
# Ale sou cloud.mongodb.com → Connect → Drivers → kopye connection string ou a
# Ranplase <username>, <password>, <cluster>, <appName> ak done reyèl ou
MONGODB_URI=<votre-connection-string-mongodb-atlas>

# ===== JWT Secret =====
# Kreye yon kle solid:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<minimum-32-karaktè-sekrè>

# ===== Mistral API =====
# Ale sou console.mistral.ai pou jwenn kle API ou a
MISTRAL_API_KEY=<votre-cle-api-mistral>

# ===== Email Gmail (SMTP) =====
# Itilize yon App Password Gmail, pa modpas nòmal ou
EMAIL_USER=<votre-email@gmail.com>
EMAIL_PASS=<votre-app-password-gmail>

# ===== Admin =====
# Email(s) ki pral jwenn role admin otomatikman (separe ak vigil si plizyè)
ADMIN_EMAILS=<admin@example.com>
ADMIN_EMAIL=<admin@example.com>
ADMIN_SECRET_KEY=<sekrè-admin-long-solid>

# ===== Site URL =====
SITE_URL=<https://votre-domaine.com>

# ===== Port =====
PORT=5000
