# ============================================================
# Radio Télé Mega Star — Variables Anviwonnman (EXAMPLE FILE)
# ============================================================
# KOPI FICHYE SA A: cp .env.example backend/.env
# RANPLI chak valè ak done reyèl OU — JAMIS push .env sou GitHub!
# .env deja nan .gitignore — VÉRIFYE anvan chak commit.
# ============================================================

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Ale sou https://cloud.mongodb.com
#   → Connect → Drivers → kopye connection string
#   → Ranplase <username> ak <password> ak vrè credentiels ou
#   → Network Access: ajoute IP Railway (oswa 0.0.0.0/0 pou prod)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0

# ─── JWT Secret (OBLIGATWA: 64+ karaktè aléatwa) ─────────────────────────────
# Jenere yon kle solid (OBLIGATWA — KOURI KÒMÀND SA A):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ⚠ JAMIS itilize mo diksyonè, non, oswa dat. 100% aléatwa obligatwa.
# ⚠ Si ou chanje kle a, TOUT JWT existant invalide — itilizatè dwe rekonekte.
JWT_SECRET=<128-karaktè-aléatwa-hex-jenere-pa-crypto.randomBytes-64>

# ─── Mistral AI ───────────────────────────────────────────────────────────────
# Ale sou https://console.mistral.ai → API Keys → Kreye nouvo kle
MISTRAL_API_KEY=<votre-cle-api-mistral>

# ─── Email SMTP (Gmail) ───────────────────────────────────────────────────────
# Itilize App Password Gmail (PAS modpas nòmal ou):
#   https://myaccount.google.com → Sekirite → Verifikasyon 2-etap → App Passwords
# Kle a gen 16 karaktè san espas (ex: abcdefghijklmnop)
EMAIL_USER=votre-email@gmail.com
EMAIL_PASS=<16-karaktè-app-password-gmail>

# ─── Admin Configuration ─────────────────────────────────────────────────────
# ADMIN_EMAILS: Email ki jwenn role admin otomatikman à l'inscription
#   Plizyè email: email1@ex.com,email2@ex.com
ADMIN_EMAILS=admin@votredomaine.com
ADMIN_EMAIL=admin@votredomaine.com

# ADMIN_SECRET_KEY: Kle bypass auth pou routes admin entèn
#   Jenere: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   ⚠ Min 32 karaktè. JAMIS placeholder. Mete menm valè nan Railway env vars.
ADMIN_SECRET_KEY=<64-karaktè-aléatwa-hex-jenere-pa-crypto.randomBytes-32>

# ─── Site URL ─────────────────────────────────────────────────────────────────
# URL piblik sit la — itilize nan lyen reset modpas
SITE_URL=https://radio-tele-megastar.pages.dev

# ─── Port ─────────────────────────────────────────────────────────────────────
PORT=5000

# ============================================================
# CHECKLIST SEKIRITE ANVAN CHAK DEPLOY
# ============================================================
# [ ] JWT_SECRET >= 64 karaktè aléatwa (pa mo diksyonè)
# [ ] ADMIN_SECRET_KEY >= 32 karaktè aléatwa (pa placeholder)
# [ ] MONGODB_URI pwen sou bon cluster Atlas ou
# [ ] MongoDB Atlas Network Access: IP Railway ajoute
# [ ] EMAIL_PASS = App Password Gmail (16 karaktè)
# [ ] SITE_URL kòrèk (https)
# [ ] Tout vars sa yo mete nan Railway dashboard → Variables
# [ ] git status pa montre .env nan uncommitted changes
# ============================================================
